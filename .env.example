# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=scm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scm
DATABASE_URL=postgres://scm:changeme@postgres:5432/scm

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=redispass

# ── JWT RS256 key pair (base64-encoded PEM) — generate with scripts/gen-keys.sh
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# ── Tokens ──────────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost

# ── Git storage ─────────────────────────────────────────────────────────────
GIT_REPOS_ROOT=/data/repos

# ── Webhooks ────────────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

# ── 2FA / TOTP ───────────────────────────────────────────────────────────────
# 32 random bytes as hex (64 hex chars) — used for AES-256-GCM encryption of TOTP secrets
# Generate: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# ── SSO / OIDC ───────────────────────────────────────────────────────────────
# Base URL used to construct the OAuth2 callback URL
SSO_CALLBACK_BASE_URL=http://localhost
# 32 random bytes as hex — used to encrypt SSO client secrets at rest
# Generate: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email (notifications will be no-ops)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@scm.example.com
SMTP_SECURE=false
